import java.util.ArrayList;
import java.util.Scanner;

class Pedido {
    private int numero;
    private String nomeCliente;
    private String itemPedido;
    private double valor;
    private String status;

    public Pedido(int numero, String nomeCliente, String itemPedido, double valor) {
        this.numero = numero;
        this.nomeCliente = nomeCliente;
        this.itemPedido = itemPedido;
        this.valor = valor;
        this.status = "PENDENTE";
    }

    public int getNumero() { return numero; }
    public String getNomeCliente() { return nomeCliente; }
    public String getItemPedido() { return itemPedido; }
    public double getValor() { return valor; }
    public String getStatus() { return status; }

    public void setStatus(String status) { this.status = status; }

    @Override
    public String toString() {
        return "Pedido #" + numero + 
               " | Cliente: " + nomeCliente + 
               " | Item: " + itemPedido + 
               " | Valor: R$ " + String.format("%.2f", valor) + 
               " | Status: " + status;
    }
}

public class JavaApplication26 {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        ArrayList<Pedido> pedidos = new ArrayList<>();
        int contadorPedidos = 1;

        int opcao;
        do {
            System.out.println("\n MENU LANCHONETE ");
            System.out.println("1 - Cadastrar pedido");
            System.out.println("2 - Listar pedidos");
            System.out.println("3 - Atualizar status de um pedido");
            System.out.println("4 - Buscar pedido pelo número");
            System.out.println("5 - Mostrar valor total dos pedidos");
            System.out.println("0 - Sair");
            System.out.print("Escolha uma opcao: ");
            opcao = scanner.nextInt();
            scanner.nextLine(); 

            switch (opcao) {
                case 1:
                    System.out.print("Nome do cliente: ");
                    String nome = scanner.nextLine();
                    System.out.print("Item pedido: ");
                    String item = scanner.nextLine();
                    System.out.print("Valor (ex: 15.50): ");
                    double valor = scanner.nextDouble();
                    
                    Pedido novoPedido = new Pedido(contadorPedidos, nome, item, valor);
                    pedidos.add(novoPedido);
                    System.out.println("Pedido #" + contadorPedidos + " cadastrado com sucesso!");
                    contadorPedidos++;
                    break;

                case 2:
                    if (pedidos.isEmpty()) {
                        System.out.println("Nenhum pedido registrado.");
                    } else {
                        for (Pedido p : pedidos) {
                            System.out.println(p);
                        }
                    }
                    break;

                case 3:
                    System.out.print("Digite o numero do pedido que deseja atualizar: ");
                    int numAtualizar = scanner.nextInt();
                    Pedido pedidoEncontrado = buscarPedido(pedidos, numAtualizar);

                    if (pedidoEncontrado != null) {
                        System.out.println("Status atual: " + pedidoEncontrado.getStatus());
                        System.out.print("Novo status (1-PENDENTE, 2-PREPARANDO, 3-FINALIZADO): ");
                        int tipoStatus = scanner.nextInt();
                        switch (tipoStatus) {
                            case 1: pedidoEncontrado.setStatus("PENDENTE"); break;
                            case 2: pedidoEncontrado.setStatus("PREPARANDO"); break;
                            case 3: pedidoEncontrado.setStatus("FINALIZADO"); break;
                            default: System.out.println("Opcao invalida. Status nao alterado.");
                        }
                        System.out.println("Status atualizado com sucesso!");
                    } else {
                        System.out.println("Pedido nao encontrado.");
                    }
                    break;

                case 4:
                    System.out.print("Digite o numero do pedido: ");
                    int numBuscar = scanner.nextInt();
                    Pedido pBuscado = buscarPedido(pedidos, numBuscar);
                    if (pBuscado != null) {
                        System.out.println(pBuscado);
                    } else {
                        System.out.println("Pedido nao encontrado.");
                    }
                    break;

                case 5:
                    double total = 0;
                    for (Pedido p : pedidos) {
                        total += p.getValor();
                    }
                    System.out.println("Valor total de todos os pedidos: R$ " + String.format("%.2f", total));
                    break;

                case 0:
                    System.out.println("Encerrando o sistema...");
                    break;

                default:
                    System.out.println("Opcao invalida!");
            }
        } while (opcao != 0);

        scanner.close();
    }

    private static Pedido buscarPedido(ArrayList<Pedido> pedidos, int numero) {
        for (Pedido p : pedidos) {
            if (p.getNumero() == numero) {
                return p;
            }
        }
        return null;
    }
}

