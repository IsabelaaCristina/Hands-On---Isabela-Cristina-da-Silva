import java.util.HashMap;
import java.util.Map;

public class JavaApplication23 {

  
    public static void main(String[] args) {
        HashMap<Integer, String> alunos = new HashMap<>();

        
        alunos.put(101, "Ana");
        alunos.put(102, "Julia");
        alunos.put(103, "Marina");
        alunos.put(104, "Yago");

        
        System.out.println("Lista de alunos cadastrados:");
        for (Map.Entry<Integer, String> aluno : alunos.entrySet()) {
            System.out.println(
                "Matrícula: " + aluno.getKey() +
                " | Nome: " + aluno.getValue()
            );
        }

       
        int matriculaBusca = 103;

        if (alunos.containsKey(matriculaBusca)) {
            System.out.println("\nAluno encontrado:");
            System.out.println("Matrícula: " + matriculaBusca +
                               " | Nome: " + alunos.get(matriculaBusca));
        } else {
            System.out.println("\nAluno não encontrado.");
        }

       
        int matriculaRemover = 102;

        if (alunos.containsKey(matriculaRemover)) {
            alunos.remove(matriculaRemover);
            System.out.println("\nAluno removido com sucesso!");
        } else {
            System.out.println("\nMatrícula não encontrada.");
        }

        
        System.out.println("\nLista atualizada:");
        for (Map.Entry<Integer, String> aluno : alunos.entrySet()) {
            System.out.println(
                "Matrícula: " + aluno.getKey() +
                " | Nome: " + aluno.getValue()
            );
        }
    }
    
}

